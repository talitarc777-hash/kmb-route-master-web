# Google Gemini API Key
# Get your free API key at: https://ai.google.dev/
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Google Cloud Platform API Key (optional, for additional features)
GCP_API_KEY=your_gcp_api_key_here

# Optional API base URL for frontend -> backend calls.
# Leave empty to use same-origin /api (recommended when frontend and API are hosted together).
# Example (separate API host): https://api.example.com
# Example (Cloudflare Workers): https://kmb-route-master-api.your-subdomain.workers.dev
VITE_API_BASE_URL=
